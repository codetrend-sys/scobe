# Project environment variables (do NOT commit this file)
# Replace the placeholders with real values before running the app.

# Formspree endpoint (create a form at https://formspree.io and copy the POST URL)
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/maqnorwo
VITE_FORMSPREE_CONTACT=https://formspree.io/f/maqnvvzw

# Optional: if you later run a backend server to send emails, set the API base URL
# Example: http://localhost:4000
VITE_API_BASE=

# Optional SMTP settings (only used if you run a server that needs them)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=example_user
# SMTP_PASS=example_password
# FROM_EMAIL=orders@yourdomain.com
# ADMIN_EMAIL=owner@yourdomain.com
# PORT=4000
